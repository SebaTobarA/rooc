// Esquema de base de datos - [NOMBRE DEL SITIO]
//
// Pilares de la v1: Item, Monster, GameMap, Drop (+ Npc como apoyo de GameMap).
// Pensado para crecer: cartas, medallas, monturas, pets, etc. se agregan como
// modelos NUEVOS (ej. "Card", "Medal", "Mount") que referencian Item/Monster
// donde corresponda, sin tocar los modelos existentes. El campo `category` en
// Item ya deja lugar para futuras variantes dentro del propio modelo si en
// algún momento conviene (ej. "equipo" vs algo liviano), pero lo normal para
// contenido realmente distinto (cartas, medallas...) es un modelo propio.

generator client {
  provider = "prisma-client-js"
}

// Postgres (Neon) tanto en desarrollo como en producción. Si en algún
// momento se quiere volver a SQLite solo en local, cambiar el provider acá
// y regenerar las migraciones (los archivos SQL son específicos por motor).
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum EquipSlot {
  WEAPON
  SHIELD
  HEAD_TOP
  HEAD_MID
  HEAD_LOW
  ARMOR
  GARMENT
  SHOES
  ACCESSORY
}

// Tipo de arma, solo aplica cuando slot = WEAPON. Se usa además para elegir
// el ícono placeholder por defecto (ver src/lib/weapon-icons.ts).
enum WeaponType {
  NONE
  SWORD
  DAGGER
  TWO_HAND_SWORD
  SPEAR
  AXE
  HATCHET
  MACE
  ROD
  STAFF
  BOW
  CROSSBOW
  KNUCKLE
  INSTRUMENT
  WHIP
  BOOK
  KATAR
  CASE
  GRASS
  SCYTHE
}

enum ItemRarity {
  COMUN
  POCO_COMUN
  RARO
  EPICO
  LEGENDARIO
}

enum Element {
  NEUTRO
  AGUA
  TIERRA
  FUEGO
  VIENTO
  VENENO
  SAGRADO
  SOMBRA
  FANTASMA
  NO_MUERTO
}

enum MonsterRace {
  HUMANOIDE
  BESTIA
  PLANTA
  NO_MUERTO
  DEMONIO
  INSECTO
  PEZ
  ANGEL
  DRAGON
  AMORFO
}

enum MonsterSize {
  PEQUENO
  MEDIANO
  GRANDE
}

// ---------------------------------------------------------------------------
// Pilar 1: Items / equipamiento
// ---------------------------------------------------------------------------

model Item {
  id   String @id @default(cuid())
  slug String @unique

  name     String
  // Campo abierto a futuro: hoy siempre "equipo". Si más adelante se decide
  // modelar cartas/medallas/monturas como filas de Item en vez de modelos
  // propios, este campo ya permite distinguirlas sin migrar la tabla.
  category String @default("equipo")

  slot       EquipSlot
  weaponType WeaponType @default(NONE)
  levelReq   Int        @default(1)
  rarity     ItemRarity @default(COMUN)

  description String @default("")
  // Texto libre con stats/bonos, ej: "+10 ATK, +5 DES, +3% resistencia a Fuego"
  // En v1 no se modelan bonos como filas estructuradas para no sobre-diseñar
  // antes de tener datos reales; si hace falta filtrar/ordenar por stat en el
  // futuro, se puede migrar a una tabla ItemStat sin romper lo existente.
  stats       String @default("")

  iconUrl       String?
  // Marca que el registro es un dato de ejemplo cargado por el seed, no un
  // dato real de la comunidad. El admin panel puede filtrar/avisar por esto.
  isPlaceholder Boolean @default(true)

  setId String?
  set   ItemSet? @relation(fields: [setId], references: [id])

  drops     Drop[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([slot])
  @@index([rarity])
  @@index([setId])
}

// ---------------------------------------------------------------------------
// Pilar 5 (agregado post-v1): Cartas
// ---------------------------------------------------------------------------

// Slot donde se inserta la carta. Distinto de EquipSlot porque las cartas
// tienen su propia grilla de slots (Main-Hand/Off-Hand en vez de Weapon,
// más Pendiente/Facewear/Mouthwear/Backwear/Costume que no existen en Item).
enum CardSlot {
  MAIN_HAND
  OFF_HAND
  ARMOR
  CLOAK
  SHOES
  ACCESSORY
  PENDIENTE
  HEADWEAR
  FACEWEAR
  MOUTHWEAR
  BACKWEAR
  COSTUME
}

enum CardRarity {
  VERDE
  AZUL
  MORADA
}

model Card {
  id   String @id @default(cuid())
  slug String @unique

  name             String
  slot             CardSlot
  rarity           CardRarity @default(VERDE)
  // clase/rol: restricción de clase, texto libre (hoy siempre vacío en los
  // datos de origen, se deja el campo para cuando se documente).
  classRestriction String     @default("")

  description     String @default("")
  // efecto/habilidad
  ability         String @default("")
  // estadisticas: texto libre tipo "FLEE: 5" o "DEX: 2, PATK: 5", igual
  // filosofía que Item.stats (no se modela como filas estructuradas en v1).
  stats           String @default("")
  // collection_bonus: bono que se obtiene por tener la carta en la colección.
  collectionBonus String @default("")
  // awaken: bonos por nivel de despertar (Lv5/Lv10/Lv15), texto libre.
  awaken          String @default("")
  // refine: bono adicional por nivel de refine, cuando aplica.
  refine          String @default("")

  iconUrl       String?
  isPlaceholder Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slot])
  @@index([rarity])
}

// ---------------------------------------------------------------------------
// Pilar 2: Bestiario (monstruos)
// ---------------------------------------------------------------------------

model Monster {
  id   String @id @default(cuid())
  slug String @unique

  name         String
  level        Int
  hp           Int
  atk          Int
  atkMax       Int?
  def          Int         @default(0)
  element      Element     @default(NEUTRO)
  elementLevel Int         @default(1)
  race         MonsterRace
  size         MonsterSize @default(MEDIANO)

  description   String  @default("")
  iconUrl       String?
  isPlaceholder Boolean @default(true)

  maps      MapMonster[]
  drops     Drop[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([level])
  @@index([race])
}

// ---------------------------------------------------------------------------
// Pilar 3: Mapas
// ---------------------------------------------------------------------------

model GameMap {
  id   String @id @default(cuid())
  slug String @unique

  name        String
  region      String
  description String @default("")

  isPlaceholder Boolean @default(true)

  monsters  MapMonster[]
  npcs      Npc[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([region])
}

// Tabla de relación N:N entre GameMap y Monster (un monstruo puede aparecer
// en varios mapas y un mapa tiene varios monstruos).
model MapMonster {
  id String @id @default(cuid())

  mapId     String
  monsterId String

  map     GameMap @relation(fields: [mapId], references: [id], onDelete: Cascade)
  monster Monster @relation(fields: [monsterId], references: [id], onDelete: Cascade)

  @@unique([mapId, monsterId])
  @@index([monsterId])
}

// NPC simple asociado a un mapa (placeholder de texto, sin posición ni ícono
// en v1, según lo pedido).
model Npc {
  id   String @id @default(cuid())
  name String
  role String @default("") // ej: "Kafra", "Comerciante", "NPC de misión"

  mapId String
  map   GameMap @relation(fields: [mapId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([mapId])
}

// ---------------------------------------------------------------------------
// Pilar 4: Tablas de drop (conecta Monster <-> Item)
// ---------------------------------------------------------------------------

model Drop {
  id String @id @default(cuid())

  monsterId String
  itemId    String
  // Porcentaje de probabilidad, ej. 12.5 = 12.5%
  rate      Float

  monster Monster @relation(fields: [monsterId], references: [id], onDelete: Cascade)
  item    Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([monsterId, itemId])
  @@index([itemId])
}

// ---------------------------------------------------------------------------
// Pilar 5: Usuarios de Discord, permisos por rol y plantillas de party
// ---------------------------------------------------------------------------

// Se crea/actualiza en cada login exitoso con Discord. `roles` cachea los IDs
// de rol del servidor al momento del login (ver src/lib/discord-bot.ts), para
// no depender de una consulta a la API de Discord en cada request.
model User {
  id          String   @id @default(cuid())
  discordId   String   @unique
  username    String
  globalName  String?
  avatarHash  String?
  roles       String[]
  // true si discordId está en ADMIN_DISCORD_IDS al momento del login. El
  // acceso a /admin siempre revalida contra esa env var, nunca confía solo
  // en este campo cacheado.
  isAdmin     Boolean  @default(false)
  lastLoginAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  partyTemplates PartyTemplate[]
  events         Event[]
  eventTemplates EventTemplate[]
}

// Mapea un rol de Discord (por su ID) a lo que puede ver/hacer dentro del
// panel. Se administra desde /admin/roles; los permisos efectivos de un
// usuario son el OR de todas las filas cuyo discordRoleId esté en User.roles.
model RolePermission {
  id               String   @id @default(cuid())
  discordRoleId    String   @unique
  // Cacheado desde la API del bot (GET /guilds/{id}/roles), se refresca cada
  // vez que se abre /admin/roles.
  roleName         String
  canViewPanel     Boolean  @default(true)
  canViewParty     Boolean  @default(true)
  canManageParty   Boolean  @default(false)
  canManageContent Boolean  @default(false)
  // Ve el módulo "Reclutamiento" en /admin/recruitment (revisar/aprobar
  // postulaciones), sin necesitar ser admin del sitio.
  canManageRecruitment Boolean @default(false)
  // Un usuario cuyo único rol con fila guardada tiene esto en true queda
  // "solo postulante": en vez del panel normal, cualquier ruta de /panel
  // lo redirige a /panel/postulacion (ver proxy.ts). Si además tiene otro
  // rol con canViewPanel true, esta bandera se ignora (getEffectivePermissions).
  isApplicantRole  Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}

enum ApplicationStatus {
  PENDING
  APPROVED
  WAITLISTED
}

// Postulación de ingreso a la guild, enviada desde /panel/postulacion por
// alguien con un rol marcado `isApplicantRole` (ej. Pronterian@s). Datos de
// Discord denormalizados igual que LeadershipMember, no hace falta un FK a
// User. Solo puede haber una postulación activa por discordId.
model GuildApplication {
  id String @id @default(cuid())

  discordId         String  @unique
  discordUsername   String
  discordAvatarHash String?

  characterName String
  className     String
  levelText     String @default("")
  availability  String
  aboutYou      String @default("")

  status     ApplicationStatus @default(PENDING)
  // Mensaje que ve el postulante junto al estado (ej. el texto de lista de
  // espera). Vacío mientras está PENDING.
  reviewNote String            @default("")

  reviewedByDiscordId String?
  reviewedByUsername  String?
  reviewedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// Administradores adicionales otorgados desde /admin/roles (además de la
// lista fija de ADMIN_DISCORD_IDS en env, que sigue siendo la única forma
// de ser "dueño" — nadie puede tocar esa lista desde la UI). Ver
// src/lib/discord-auth.ts (isAllowedAdminId) e isDbAdmin en permissions.ts.
model AdminGrant {
  id String @id @default(cuid())

  discordId  String  @unique
  username   String
  avatarHash String?

  grantedByDiscordId String?

  createdAt DateTime @default(now())
}

model PartyTemplate {
  id          String @id @default(cuid())
  event       String
  name        String
  // Estado completo de parties/slots (mismo shape que useCampo en el party builder).
  data        Json
  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  // Evento de Discord del que salieron los jugadores, si se armó desde ahí
  // (ver src/lib/party/from-signups.ts). Opcional — sigue existiendo el
  // import manual sin evento. SetNull para que borrar el Event no borre la
  // plantilla ya guardada. Se llama `sourceEvent` (no `event`) porque ese
  // nombre ya lo usa el campo de texto libre de arriba.
  eventId     String?
  sourceEvent Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([event])
}

// ---------------------------------------------------------------------------
// Asistencia a eventos (Guild League / Emperium Overrun): se crean en
// /panel/eventos (gestión de guild, permiso canManageParty) y, al enviarse,
// el bot postea un roster con botones en Discord (ver src/lib/events.ts y
// src/app/api/discord/interactions). `channelId`/`messageId` quedan
// grabados al enviar para que el endpoint de interacciones pueda editar el
// mensaje sin depender del request original.
// ---------------------------------------------------------------------------

enum EventCategory {
  GUILD_LEAGUE
  EMPERIUM_OVERRUN
}

enum EventStatus {
  DRAFT
  PUBLISHED
}

enum EventSignupStatus {
  CONFIRMED
  LATE
  NOT_ATTENDING
}

// Configuración reutilizable de estilo del embed (color, ícono) — se crea
// una vez por tipo de evento y se reusa cada vez que se carga una fecha
// nueva, para no reconfigurar el estilo en cada evento.
model EventTemplate {
  id         String        @id @default(cuid())
  title      String
  // Emoji corto opcional, antepuesto al título del embed en Discord.
  icon       String?
  embedColor String        @default("#6fe0f5")
  category   EventCategory

  createdById String
  createdBy   User    @relation(fields: [createdById], references: [id])
  events      Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Fila única — a qué canal de Discord se publican los eventos, editable
// desde /panel/eventos. La app siempre lee/actualiza el primer registro.
model GuildEventSettings {
  id               String   @id @default(cuid())
  defaultChannelId String?
  updatedAt        DateTime @updatedAt
}

model Event {
  id          String        @id @default(cuid())
  title       String
  description String        @default("")
  // Copiada del template elegido al crear el evento.
  category    EventCategory
  templateId  String
  template    EventTemplate @relation(fields: [templateId], references: [id])

  startsAt       DateTime
  endsAt         DateTime
  // Hasta cuándo se aceptan altas/cambios de inscripción — lo carga quien
  // crea el evento, independiente de startsAt/endsAt.
  signupsCloseAt DateTime

  status      EventStatus @default(DRAFT)
  channelId   String?
  messageId   String?
  publishedAt DateTime?

  createdById    String
  createdBy      User            @relation(fields: [createdById], references: [id])
  signups        EventSignup[]
  partyTemplates PartyTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// Snapshot (`displayName`/`className`/`classRoleId`) re-derivado desde
// Discord en cada interacción del bot — el embed y las tablas de admin se
// renderizan solo desde acá, sin pegarle a la API de Discord en cada lectura.
model EventSignup {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  discordId   String
  displayName String
  className   String
  classRoleId String

  status    EventSignupStatus @default(CONFIRMED)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([eventId, discordId])
  @@index([eventId, status])
}

// ---------------------------------------------------------------------------
// Liderazgo: cargos y miembros mostrados en la home, gestionados desde
// /admin/leadership. Los miembros se eligen de la lista real de Discord
// (ver src/lib/discord-bot.ts) al agregarlos.
// ---------------------------------------------------------------------------

model LeadershipPosition {
  id        String             @id @default(cuid())
  title     String
  // Determina el número de rango (01, 02...) y el orden en pantalla.
  order     Int
  members   LeadershipMember[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([order])
}

model LeadershipMember {
  id         String             @id @default(cuid())
  positionId String
  position   LeadershipPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)

  discordId         String
  discordUsername   String
  discordAvatarHash String?
  // Editable desde el admin; se precarga con el nick/username de Discord al
  // agregar al miembro pero puede diferir del apodo real en el juego.
  nickname          String
  order             Int      @default(0)
  createdAt         DateTime @default(now())

  @@index([positionId])
}

// ---------------------------------------------------------------------------
// Sets de equipamiento ("build effect"): stat base por tener una pieza, más
// bonos que se destraban por nivel de refine y por cantidad de piezas
// equipadas del mismo set.
// ---------------------------------------------------------------------------

model ItemSet {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  // Bono que se obtiene solo por equipar una pieza del set, ej. "Max HP +100".
  baseStatText String @default("")

  items        Item[]
  tiers        ItemSetTier[]
  pieceBonuses ItemSetPieceBonus[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ItemSetTier {
  id    String  @id @default(cuid())
  setId String
  set   ItemSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  // Nivel de refine que destraba este bono (3, 6, 10, 12, 15...).
  refineLevel Int
  statText    String

  @@unique([setId, refineLevel])
}

model ItemSetPieceBonus {
  id    String  @id @default(cuid())
  setId String
  set   ItemSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  // Cantidad de piezas del set equipadas simultáneamente (2, 3, 4...).
  pieceCount Int
  statText   String

  @@unique([setId, pieceCount])
}

// ---------------------------------------------------------------------------
// Build PVP: árbol de clases y de habilidades para el simulador de
// /panel/build-pvp, armado desde /admin/build-pvp. Un "build" completo
// recorre 3 Job en cadena (primera clase -> segunda clase -> segunda clase
// transcendente, ej. Swordsman -> Knight -> Lord Knight), cada uno con su
// propio árbol de hasta 40 puntos. La asignación de puntos en sí se arma en
// el cliente (SkillPlanner) y solo se persiste como SavedBuild cuando el
// jugador decide guardarla.
// ---------------------------------------------------------------------------

enum JobTier {
  FIRST
  SECOND
  TRANSCENDENT
}

model Job {
  id   String  @id @default(cuid())
  name String
  tier JobTier
  // Orden entre hermanos (columnas en el selector, o ramas dentro de una
  // misma clase base, ej. Knight antes que Crusader).
  order Int    @default(0)

  iconUrl     String?
  // Retrato de cuerpo/busto mostrado en la tarjeta de personaje del
  // simulador cuando este Job (siempre TRANSCENDENT) está seleccionado.
  portraitUrl String?

  parentId String?
  parent   Job?    @relation("JobTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Job[]   @relation("JobTree")

  skills Skill[]
  builds SavedBuild[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([tier])
}

model Skill {
  id    String @id @default(cuid())
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  name     String
  iconUrl  String?
  maxLevel Int     @default(10)
  // Descripción de cada nivel (índice 0 = nivel 1, etc.) — se muestra la
  // que corresponda al nivel actualmente invertido en el simulador.
  levelDescriptions String[] @default([])

  // Posición en la grilla del árbol (columna/fila), igual que en el
  // cliente del juego — la editás a mano desde /admin/build-pvp.
  col Int @default(0)
  row Int @default(0)

  // Skills que dependen de esta (para borrar/editar desde cualquier lado).
  requiredBy    SkillPrerequisite[] @relation("RequiredSkill")
  // Prerequisitos de esta skill.
  prerequisites SkillPrerequisite[] @relation("DependentSkill")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
}

// Relación N:N con nivel mínimo requerido — una skill puede necesitar
// varias otras (ej. Spear Stab necesita Spear Mastery Y Pierce).
model SkillPrerequisite {
  id String @id @default(cuid())

  skillId String
  skill   Skill  @relation("DependentSkill", fields: [skillId], references: [id], onDelete: Cascade)

  requiresSkillId String
  requiresSkill   Skill  @relation("RequiredSkill", fields: [requiresSkillId], references: [id], onDelete: Cascade)

  requiredLevel Int @default(1)

  @@unique([skillId, requiresSkillId])
}

// Build guardada desde el simulador (jugador que arma y le pone nombre a
// una asignación de puntos). Arranca en DRAFT — solo la ve el historial de
// /panel/build-pvp (canManageParty). Al pasar a SENT, se libera a la vista
// de cualquier jugador cuyo rol de clase en Discord coincida con `job`
// (mismo cruce que ya usa /panel/perfil vía discord-job-roles.ts) — no solo
// a quien la creó. DEACTIVATED la vuelve a ocultar sin borrarla.
enum BuildStatus {
  DRAFT
  SENT
  DEACTIVATED
}

model SavedBuild {
  id   String @id @default(cuid())
  name String

  // Siempre la clase TRANSCENDENT elegida en el selector — el resto de la
  // cadena (1st/2nd) se deriva de su parent/parent.parent.
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // { [skillId]: nivel } de las 3 clases de la cadena.
  allocations Json

  createdByDiscordId String
  createdByUsername  String

  status BuildStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([status])
}
