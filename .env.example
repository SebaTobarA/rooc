# Copiá este archivo a ".env" y completá los valores.
# Ver README.md para instrucciones detalladas de cada variable.

# --- Base de datos --------------------------------------------------------
# Postgres serverless (Neon o Supabase), misma base para dev y producción.
# Ver README > "Base de datos" para cómo generar la tuya.
DATABASE_URL="postgresql://usuario:password@host/db?sslmode=require"

# --- Admin panel -----------------------------------------------------------
# Credenciales del panel de administración (usuario único, sin sistema de
# cuentas). Cambialas antes de desplegar a producción.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="cambiame123"

# Secreto usado para firmar la cookie de sesión del admin. Generá uno propio
# con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET="reemplazar-por-un-secreto-largo-y-aleatorio"

# --- Login con Discord (para todos los usuarios, y alternativa al
# usuario/contraseña del admin) ---------------------------------------------
# Creá una app en https://discord.com/developers/applications, sección
# OAuth2, y agregá como redirect URI:
#   http://localhost:3000/api/auth/discord/callback (desarrollo)
#   https://tu-dominio/api/auth/discord/callback (producción)
DISCORD_CLIENT_ID="reemplazar-con-el-client-id-de-tu-app-de-discord"
DISCORD_CLIENT_SECRET="reemplazar-con-el-client-secret-de-tu-app-de-discord"

# IDs de Discord (separados por coma) que pueden entrar al panel admin.
# Activá el "Modo desarrollador" en Discord (Configuración > Avanzado) para
# poder copiar tu ID de usuario con clic derecho sobre tu perfil.
ADMIN_DISCORD_IDS="123456789012345678"

# --- Bot de Discord (verifica membresía/roles del server en el login, y
# alimenta /admin/members y /admin/roles) -----------------------------------
# En la misma app de arriba, pestaña "Bot" -> "Add Bot" -> copiá el token.
# Activá también "Server Members Intent" en esa misma pestaña, e invitá el
# bot al server (OAuth2 -> URL Generator -> scope "bot").
DISCORD_BOT_TOKEN="reemplazar-con-el-token-del-bot"

# ID del server (guild) de Special Delivery. Clic derecho sobre el ícono del
# server con "Modo desarrollador" activado.
DISCORD_GUILD_ID="reemplazar-con-el-id-del-server"
